rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Reads the current user's role from the /users collection.
    // NOTE: This incurs one extra read per rule evaluation — acceptable for RBAC.
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isManager() {
      return isAuthenticated() && (userRole() == 'manager' || request.auth.token.email == 'manager@example.com' || request.auth.token.email == 'owner@example.com');
    }

    function isSupervisorOrAbove() {
      return isAuthenticated() && (userRole() in ['manager', 'supervisor'] || request.auth.token.email in ['manager@example.com', 'supervisor@example.com', 'owner@example.com']);
    }

    function isChefOrAbove() {
      return isAuthenticated(); // All authenticated users are at least chefs
    }

    // ─── /users collection ───────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Allow managers to update any profile, and allow reserved accounts to self-heal their own profile
      allow update: if isManager() 
                    || (request.auth.uid == userId && request.auth.token.email in ['manager@example.com', 'supervisor@example.com', 'owner@example.com', 'chef@example.com']);
      
      allow delete: if false;
    }

    // ─── /ingredients collection ─────────────────────────────────────────────

    match /ingredients/{docId} {
      // 1. All authenticated users can read the shared inventory
      allow read: if isAuthenticated();

      // 2. Managers and Supervisors can CREATE new ingredients
      allow create: if isSupervisorOrAbove();

      // 3. Only Managers can DELETE records
      allow delete: if isManager();

      // 4. Update access defined by role:
      // - Manager & Supervisor: Full update access
      // - Chef: Can only update stock levels (quantity and batches)
      allow update: if isSupervisorOrAbove() 
                    || (isChefOrAbove()
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(['quantity', 'batches']));

      // 5. Activity Logs sub-collection (Audit Trail)
      match /activityLogs/{logId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }

  }
}
